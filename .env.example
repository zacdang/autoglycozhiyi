# ── Pipeline mode ─────────────────────────────────────────────────────────────
# "mock" → use pre-built sample data, no external tools needed
# "real" → call real MERMaid (VisualHeist + DataRaider) and ChemDataExtractor
PIPELINE_MODE=mock

# ── OpenAI API key (required for real mode — DataRaider uses GPT-4o) ─────────
# Switch between keys here anytime — change this line, save, and re-run.
OPENAI_API_KEY=sk-your-key-here

# ── Path to the cloned MERMaid repository ────────────────────────────────────
# DataRaider needs the Prompts/ directory inside MERMaid.
MERMAID_REPO_PATH=../MERMaid

# ── Data directories (relative to project root) ───────────────────────────────
DATA_DIR=data
SAMPLES_DIR=data/samples
MERMAID_OUTPUT_DIR=data/mermaid_outputs
CDE_OUTPUT_DIR=data/cde_outputs
PARSED_DIR=data/parsed
INTERMEDIATE_DIR=data/intermediate
OUTPUT_DIR=data/outputs
